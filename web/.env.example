# Nameless web — environment configuration (copy to `.env` to override defaults).
#
# Which API client the app uses at runtime:
#   - "mock" (default): the in-memory MockNamelessApi with seeded fixtures. No backend needed.
#   - "http": the HttpNamelessApi talking to the real axum control plane at VITE_API_BASE_URL.
VITE_NAMELESS_CLIENT=mock

# Base URL of the running Rust control-plane HTTP API (only used when VITE_NAMELESS_CLIENT=http).
# This wiring is env-gated: the axum server is built in the Rust crates but is not run on the
# 4GB dev box. Point this at the server once it is running locally or hosted.
VITE_API_BASE_URL=http://127.0.0.1:8080
