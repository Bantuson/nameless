# Nameless server profile configuration (the `postgres`-feature, non-`--local` path).
# Copy to `.env` and fill in. `.env` is git-ignored; this example holds placeholders only.
#
# The default `--local` profile needs NONE of these — it runs on the filesystem + in-memory
# adapters with no Postgres and no S3. These are only required for the production backend
# (`nameless` built with `--features postgres`, run WITHOUT `--local`).

# --- Postgres (PostgresFragmentRepo + SqlxmqJobQueue) ---
# A Postgres 16/17 database. Neon, a local server, or any managed PG works.
# Required at COMPILE time too if you build with sqlx's compile-time-checked macros and no offline
# cache — either point this at a migrated DB before `cargo build --features postgres`, or run
# `cargo sqlx prepare` to generate the offline `.sqlx` cache and build with SQLX_OFFLINE=true.
DATABASE_URL=postgres://user:password@localhost:5432/nameless

# --- S3 / Cloudflare R2 (S3ObjectStore) — immutable audio storage by content hash ---
NAMELESS_STORAGE_BUCKET=nameless-audio
NAMELESS_STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
NAMELESS_STORAGE_REGION=auto
NAMELESS_STORAGE_ACCESS_KEY_ID=your-r2-access-key-id
NAMELESS_STORAGE_SECRET_ACCESS_KEY=your-r2-secret-access-key
